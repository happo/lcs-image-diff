{
  "name": "lcs-image-diff",
  "version": "3.0.0",
  "description": "A JavaScript library to diff two images. Uses the Longest-Common-Subsequence algorithm to allow content to shift.",
  "type": "module",
  "main": "src/index.js",
  "files": [
    "src/*.js"
  ],
  "authors": [
    "Henric Persson <henric@happo.io>",
    "Joe Lencioni <joe@happo.io>"
  ],
  "repository": {
    "type": "git",
    "url": "https://github.com/happo/lcs-image-diff.git"
  },
  "license": "MIT",
  "scripts": {
    "test": "node --experimental-vm-modules node_modules/.bin/jest",
    "serve": "node server.js"
  },
  "prettier": {
    "trailingComma": "all",
    "tabWidth": 2,
    "semi": true,
    "singleQuote": true,
    "printWidth": 80,
    "arrowParens": "avoid"
  },
  "dependencies": {
    "imagetracerjs": "^1.2.5"
  },
  "devDependencies": {
    "jest": "^29.7.0",
    "sharp": "^0.34.1"
  }
}
